#!/usr/bin/env bash
set -euo pipefail

EVENT="${1:-}"
VAULTS_DIR="$HOME/vaults"
ACTIVE_VAULT_FILE="$VAULTS_DIR/.active-vault"

if [ -z "$EVENT" ] || [ "$EVENT" != "stop" ]; then
  exit 0
fi

# Read active vault path
if [ ! -f "$ACTIVE_VAULT_FILE" ]; then
  exit 0
fi

VAULT_DIR=$(cat "$ACTIVE_VAULT_FILE" 2>/dev/null | tr -d '[:space:]')

if [ -z "$VAULT_DIR" ] || [ ! -d "$VAULT_DIR/.git" ]; then
  exit 0
fi

cd "$VAULT_DIR"

# Only commit if there are changes
if git diff --quiet && git diff --cached --quiet && [ -z "$(git ls-files --others --exclude-standard)" ]; then
  exit 0
fi

git add -A 2>/dev/null || true
git commit -m "session: $(date -u +%Y-%m-%dT%H:%M:%SZ)" --no-verify 2>/dev/null || true
